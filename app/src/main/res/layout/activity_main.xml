<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <TextView
            android:text="Lynx Spoofer"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Settings.Secure spoof control"
            android:textSize="13sp"
            android:layout_marginBottom="32dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnKeybox"
            android:text="Select Keybox XML"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvKeyboxStatus"
            android:text="No keybox loaded"
            android:textSize="12sp"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnPif"
            android:text="Select pif.json"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvPifStatus"
            android:text="No pif.json loaded"
            android:textSize="12sp"
            android:layout_marginBottom="32dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnReset"
            android:text="Reset Spoofing"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#B71C1C"/>

        <Button
            android:id="@+id/btnIntegrity"
            android:text="Check Integrity"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#1B5E20"/>

        <TextView
            android:id="@+id/tvLog"
            android:text=""
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginTop="28dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>